# ===========================================================================
# TID backend — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is git-ignored. NEVER commit real credentials.
# ===========================================================================

# ---- MongoDB ----
# Atlas connection string. URL-encode any special characters in the password.
# Get this from Atlas → Database → Connect → Drivers.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tid?retryWrites=true&w=majority

# Database name to use inside the cluster.
MONGODB_DB=tid

# ---- JWT ----
# Generate a 64-byte random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-real-64-byte-hex-string-generated-locally
JWT_EXPIRES_IN=30m

# ---- Password hashing ----
# Higher = slower (good for defense). 12 ≈ 250ms on a typical server.
# Bump to 13 if you have CPU headroom.
BCRYPT_ROUNDS=12

# ---- CORS ----
# Comma-separated list of origins allowed to call this API.
# In dev: http://localhost:4200
# In prod: ONLY your deployed frontend(s). Never use "*" — that disables
# CORS protection.
CORS_ORIGINS=http://localhost:4200

# ---- Server bind ----
HOST=0.0.0.0
PORT=3001

# Set to "production" when deployed.
# In production: HSTS is enabled, dev pretty-logs are off, JWT_SECRET length
# is enforced (≥32 chars).
NODE_ENV=development
